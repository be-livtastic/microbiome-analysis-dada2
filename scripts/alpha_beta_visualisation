#!/usr/bin/env Rscript
# Alpha and beta diversity visualisation workflow
#
# This script reads the processed DADA2 outputs, rebuilds a phyloseq object,
# converts it to relative abundance (ps_rel), and writes publication-style
# figures into outputs/figures/ using the repository's existing naming pattern.

options(warn = 1)
set.seed(1)

cat("Starting alpha and beta diversity visualisation workflow...\n")

choose_file <- function(cands) {
	existing <- cands[file.exists(cands)]
	if (length(existing) == 0) {
		return(NA_character_)
	}
	existing[1]
}

check_pkg <- function(pkg) {
	if (!requireNamespace(pkg, quietly = TRUE)) {
		stop(sprintf(
			"Required package '%s' is not installed. Install it with install.packages('%s') or BiocManager::install('%s') if appropriate.",
			pkg,
			pkg,
			pkg
		))
	}
}

required_pkgs <- c(
	"phyloseq",
	"microbiome",
	"ComplexHeatmap",
	"circlize",
	"ggplot2",
	"dplyr",
	"tidyr",
	"vegan",
	"ape",
	"RColorBrewer",
	"scales"
)

for (pkg in required_pkgs) {
	check_pkg(pkg)
}

library(phyloseq)
library(microbiome)
library(ComplexHeatmap)
library(circlize)
library(ggplot2)
library(dplyr)
library(tidyr)
library(vegan)
library(ape)
library(RColorBrewer)
library(scales)

out_fig_dir <- file.path("outputs", "figures")
out_alpha_dir <- file.path("outputs", "alpha_beta")
dir.create(out_fig_dir, recursive = TRUE, showWarnings = FALSE)
dir.create(out_alpha_dir, recursive = TRUE, showWarnings = FALSE)

asv_candidates <- c(
	file.path("data", "processed", "dada2", "ASV_paired_end_table.rds"),
	file.path("outputs", "ASV_paired_end_table.rds"),
	file.path("data", "processed", "dada2", "single_end", "ASV_table_SE.rds"),
	file.path("outputs", "single_end", "ASV_table_SE.rds")
)

tax_candidates <- c(
	file.path("outputs", "single_end", "taxonomy_SE.rds"),
	file.path("outputs", "single_end", "taxonomy_SE_genuslevel.rds"),
	file.path("data", "processed", "dada2", "taxonomy.rds")
)

meta_candidates <- c(
	file.path("data", "processed", "dada2", "metadata.csv"),
	file.path("data", "processed", "dada2", "sample_metadata.csv"),
	file.path("outputs", "metadata.csv"),
	file.path("outputs", "sample_metadata.csv")
)

tree_candidates <- c(
	file.path("outputs", "phylogeny", "asv_tree_ml.rds"),
	file.path("outputs", "asv_tree_ml.rds"),
	file.path("phylogeny", "asv_tree_ml.rds")
)

alpha_metrics_candidates <- c(
	file.path(out_alpha_dir, "alpha_metrics.csv"),
	file.path("outputs", "alpha_beta", "alpha_metrics.csv")
)

asv_path <- choose_file(asv_candidates)
if (is.na(asv_path)) {
	stop("No ASV table found. Looked in data/processed/dada2 and outputs/.")
}

tax_path <- choose_file(tax_candidates)
meta_path <- choose_file(meta_candidates)
tree_path <- choose_file(tree_candidates)
alpha_metrics_path <- choose_file(alpha_metrics_candidates)

cat("Loading ASV table from:", asv_path, "\n")
asv_obj <- readRDS(asv_path)
asv_mat <- as.matrix(asv_obj)

if (is.null(colnames(asv_mat))) {
	stop("ASV table has no column names; cannot match taxa to taxonomy or tree.")
}

taxonomy_obj <- NULL
if (!is.na(tax_path)) {
	cat("Loading taxonomy from:", tax_path, "\n")
	taxonomy_obj <- tryCatch(readRDS(tax_path), error = function(e) {
		warning("Could not read taxonomy RDS: ", conditionMessage(e))
		NULL
	})
}

sample_metadata <- NULL
if (!is.na(meta_path)) {
	cat("Loading metadata from:", meta_path, "\n")
	sample_metadata <- tryCatch(
		read.csv(meta_path, stringsAsFactors = FALSE, row.names = 1),
		error = function(e) {
			warning("Could not read metadata CSV: ", conditionMessage(e))
			NULL
		}
	)
}

phy_tree_obj <- NULL
if (!is.na(tree_path)) {
	cat("Loading phylogenetic tree from:", tree_path, "\n")
	phy_tree_obj <- tryCatch(readRDS(tree_path), error = function(e) {
		warning("Could not read tree RDS: ", conditionMessage(e))
		NULL
	})
}

common_taxa <- colnames(asv_mat)
if (!is.null(taxonomy_obj)) {
	tax_mat <- as.matrix(taxonomy_obj)
	tax_ids <- rownames(tax_mat)
	shared_taxa <- intersect(common_taxa, tax_ids)
	if (length(shared_taxa) > 0) {
		common_taxa <- shared_taxa
		asv_mat <- asv_mat[, common_taxa, drop = FALSE]
		tax_mat <- tax_mat[common_taxa, , drop = FALSE]
		taxonomy_obj <- tax_mat
	} else {
		warning("Taxonomy row names do not match ASV identifiers. Taxonomy-based plots may be skipped.")
		taxonomy_obj <- NULL
	}
}

common_samples <- rownames(asv_mat)
if (!is.null(sample_metadata)) {
	sample_metadata <- sample_metadata[intersect(rownames(sample_metadata), rownames(asv_mat)), , drop = FALSE]
	common_samples <- intersect(rownames(asv_mat), rownames(sample_metadata))
	asv_mat <- asv_mat[common_samples, , drop = FALSE]
	sample_metadata <- sample_metadata[common_samples, , drop = FALSE]
}

otu <- otu_table(asv_mat, taxa_are_rows = FALSE)

components <- list(otu = otu)
if (!is.null(taxonomy_obj)) {
	components$tax <- tax_table(as.matrix(taxonomy_obj))
}
if (!is.null(sample_metadata)) {
	components$sd <- sample_data(sample_metadata)
}

ps <- do.call(phyloseq, components)
ps <- prune_samples(sample_sums(ps) > 0, ps)

# Relative abundance is the plotting scale used throughout this file.
# ps_rel keeps each sample summing to 1.0, which prevents sequencing depth from
# driving visual differences in barplots, heatmaps, and ordinations.
ps_rel <- transform_sample_counts(ps, function(x) {
	total <- sum(x)
	if (total == 0) {
		return(x)
	}
	x / total
})

ps_rel <- prune_samples(sample_sums(ps_rel) > 0, ps_rel)

pick_group_var <- function(meta) {
	if (is.null(meta) || ncol(meta) == 0) {
		return(NA_character_)
	}

	candidate_names <- c("Group", "group", "Treatment", "treatment", "SampleType", "sample_type", "Condition", "condition")
	direct <- intersect(candidate_names, colnames(meta))
	if (length(direct) > 0) {
		return(direct[1])
	}

	is_categorical <- function(vec, n) {
		values <- unique(vec)
		values <- values[!is.na(values)]
		length(values) > 1 && length(values) < n
	}

	possible <- colnames(meta)[vapply(meta, is_categorical, logical(1), n = nrow(meta))]
	if (length(possible) > 0) {
		possible[1]
	} else {
		NA_character_
	}
}

group_var <- pick_group_var(sample_metadata)
if (!is.na(group_var)) {
	cat("Using grouping variable:", group_var, "\n")
} else {
	cat("No obvious grouping variable found in metadata; plots will use sample order only.\n")
}

ordered_samples <- sample_names(ps_rel)
sample_depths <- sample_sums(ps)
if (!is.null(sample_metadata) && !is.na(group_var) && group_var %in% colnames(sample_metadata)) {
	group_key <- as.character(sample_metadata[sample_names(ps_rel), group_var])
	group_key[is.na(group_key)] <- "zzz_unassigned"
	ordered_samples <- sample_names(ps_rel)[order(group_key, -sample_depths[sample_names(ps_rel)], sample_names(ps_rel))]
} else {
	ordered_samples <- sample_names(ps_rel)[order(-sample_depths[sample_names(ps_rel)], sample_names(ps_rel))]
}

alpha_metrics <- NULL
if (!is.na(alpha_metrics_path)) {
	cat("Loading alpha metrics from:", alpha_metrics_path, "\n")
	alpha_metrics <- tryCatch(read.csv(alpha_metrics_path, row.names = 1, check.names = FALSE), error = function(e) {
		warning("Could not read alpha metrics CSV: ", conditionMessage(e))
		NULL
	})
}

if (is.null(alpha_metrics)) {
	cat("Alpha metrics CSV not found; computing core metrics from the phyloseq object.\n")
	alpha_metrics <- estimate_richness(ps, measures = c("Observed", "Shannon", "Simpson"))
	if ("Simpson" %in% colnames(alpha_metrics)) {
		alpha_metrics$Simpson <- 1 - alpha_metrics$Simpson
	}
	if ("Faith_PD" %in% colnames(alpha_metrics)) {
		alpha_metrics$Faith_PD <- alpha_metrics$Faith_PD
	}
}

alpha_metrics$Sample <- rownames(alpha_metrics)
if (!is.null(sample_metadata)) {
	alpha_metrics <- merge(alpha_metrics, sample_metadata, by.x = "Sample", by.y = "row.names", all.x = TRUE)
}

alpha_long <- alpha_metrics %>%
	select(Sample, any_of(c("Observed", "Shannon", "Simpson", "Faith_PD")), everything()) %>%
	pivot_longer(
		cols = any_of(c("Observed", "Shannon", "Simpson", "Faith_PD")),
		names_to = "Metric",
		values_to = "Value"
	)

if (nrow(alpha_long) > 0) {
	alpha_long$Sample <- factor(alpha_long$Sample, levels = ordered_samples)
	if (!is.na(group_var) && group_var %in% colnames(alpha_long)) {
		alpha_long[[group_var]] <- as.factor(alpha_long[[group_var]])
	}

	p_alpha <- ggplot(alpha_long, aes(x = Sample, y = Value)) +
		geom_boxplot(outlier.shape = NA, fill = "#d9e8fb", color = "#4c78a8", width = 0.7) +
		facet_wrap(~Metric, scales = "free_y", ncol = 2) +
		labs(
			title = "Alpha diversity summary",
			x = "Sample",
			y = "Metric value"
		) +
		theme_minimal(base_size = 12) +
		theme(
			axis.text.x = element_text(angle = 45, hjust = 1),
			legend.position = if (!is.na(group_var) && group_var %in% colnames(alpha_long)) "top" else "none"
		)

	if (!is.na(group_var) && group_var %in% colnames(alpha_long)) {
		p_alpha <- p_alpha +
			geom_point(aes(color = .data[[group_var]]), size = 1.8, alpha = 0.75, position = position_jitter(width = 0.12, height = 0)) +
			labs(color = group_var)
	} else {
		p_alpha <- p_alpha +
			geom_point(size = 1.8, alpha = 0.75, position = position_jitter(width = 0.12, height = 0))
	}

	ggsave(
		filename = file.path(out_fig_dir, "alpha_diversity_summary_boxplots.png"),
		plot = p_alpha,
		width = 12,
		height = 7,
		dpi = 300
	)
	cat("Saved alpha diversity summary plot to outputs/figures/alpha_diversity_summary_boxplots.png\n")
}

top_taxon_palette <- function(level_values) {
	n <- length(level_values)
	if (n <= 0) {
		return(character())
	}
	n_core <- max(1, n - 1)
	core_cols <- grDevices::hcl.colors(n_core, palette = "Dark 3")
	cols <- setNames(c(core_cols, "#d9d9d9"), c(level_values[seq_len(n_core)], "Other"))
	cols
}

prepare_barplot <- function(ps_obj, rank, top_n = 10) {
	if (is.null(tax_table(ps_obj, errorIfNULL = FALSE))) {
		return(NULL)
	}

	bar_ps <- tryCatch(
		microbiome::aggregate_top_taxa2(ps_obj, level = rank),
		error = function(e) {
			warning(sprintf("microbiome::aggregate_top_taxa2 failed for %s: %s", rank, conditionMessage(e)))
			phyloseq::tax_glom(ps_obj, taxrank = rank, NArm = FALSE)
		}
	)

	tax_df <- as.data.frame(tax_table(bar_ps), stringsAsFactors = FALSE)
	if (!rank %in% colnames(tax_df)) {
		warning(sprintf("Taxonomic rank '%s' was not found for the barplot.", rank))
		return(NULL)
	}

	abund <- taxa_sums(bar_ps)
	top_taxa <- names(sort(abund, decreasing = TRUE))[seq_len(min(top_n, length(abund)))]
	tax_df[[rank]] <- as.character(tax_df[[rank]])
	tax_df[[rank]][is.na(tax_df[[rank]]) | tax_df[[rank]] == ""] <- "Unassigned"
	tax_df$PlotTaxon <- ifelse(tax_df[[rank]] %in% top_taxa, tax_df[[rank]], "Other")
	tax_df$PlotTaxon <- factor(tax_df$PlotTaxon, levels = c(top_taxa, "Other"))
	tax_table(bar_ps) <- tax_table(as.matrix(tax_df))

	sample_order <- sample_names(bar_ps)
	if (!is.null(sample_metadata)) {
		meta_df <- as.data.frame(sample_data(bar_ps))
		if (!is.na(group_var) && group_var %in% colnames(meta_df)) {
			group_key <- as.character(meta_df[[group_var]])
			group_key[is.na(group_key)] <- "zzz_unassigned"
			sample_order <- rownames(meta_df)[order(group_key, -sample_sums(bar_ps)[rownames(meta_df)], rownames(meta_df))]
		} else {
			sample_order <- rownames(meta_df)[order(-sample_sums(bar_ps)[rownames(meta_df)], rownames(meta_df))]
		}
	}

	sample_df <- as.data.frame(sample_data(bar_ps))
	sample_df$Sample <- factor(rownames(sample_df), levels = sample_order)
	sample_data(bar_ps) <- sample_data(sample_df)

	p <- plot_bar(bar_ps, x = "Sample", fill = "PlotTaxon") +
		labs(
			title = paste0("Relative abundance at ", rank, " level"),
			x = "Sample",
			y = "Relative abundance"
		) +
		theme_bw(base_size = 11) +
		theme(
			axis.text.x = element_text(angle = 60, hjust = 1, vjust = 1),
			legend.position = "top",
			legend.title = element_text(size = 10),
			legend.text = element_text(size = 9)
		) +
		scale_fill_manual(values = top_taxon_palette(levels(droplevels(tax_df$PlotTaxon))))

	if (!is.na(group_var) && group_var %in% sample_variables(bar_ps)) {
		p <- p + facet_grid(reformulate(group_var), scales = "free_x", space = "free_x")
	}

	list(phyloseq = bar_ps, plot = p, top_taxa = top_taxa)
}

bar_phylum <- prepare_barplot(ps_rel, "Phylum", top_n = 10)
if (!is.null(bar_phylum)) {
	ggsave(
		filename = file.path(out_fig_dir, "taxonomic_barplot_phylum_relative_abundance.png"),
		plot = bar_phylum$plot,
		width = 14,
		height = 7,
		dpi = 300
	)
	cat("Saved phylum barplot to outputs/figures/taxonomic_barplot_phylum_relative_abundance.png\n")
}

bar_genus <- prepare_barplot(ps_rel, "Genus", top_n = 10)
if (!is.null(bar_genus)) {
	ggsave(
		filename = file.path(out_fig_dir, "taxonomic_barplot_genus_relative_abundance.png"),
		plot = bar_genus$plot,
		width = 14,
		height = 7,
		dpi = 300
	)
	cat("Saved genus barplot to outputs/figures/taxonomic_barplot_genus_relative_abundance.png\n")
}

make_pcoa_plot <- function(dist_obj, ps_obj, title, file_name, group_var = NA_character_) {
	pcoa_res <- ape::pcoa(as.dist(dist_obj))
	scores <- as.data.frame(pcoa_res$vectors[, 1:2, drop = FALSE])
	colnames(scores) <- c("Axis1", "Axis2")
	scores$Sample <- rownames(scores)

	if (!is.na(group_var) && group_var %in% sample_variables(ps_obj)) {
		meta_df <- as.data.frame(sample_data(ps_obj))
		scores <- merge(scores, meta_df, by.x = "Sample", by.y = "row.names", all.x = TRUE)
	}

	axis1 <- round(100 * pcoa_res$values$Relative_eig[1], 1)
	axis2 <- round(100 * pcoa_res$values$Relative_eig[2], 1)

	p <- ggplot(scores, aes(x = Axis1, y = Axis2)) +
		geom_hline(yintercept = 0, color = "grey85", linewidth = 0.3) +
		geom_vline(xintercept = 0, color = "grey85", linewidth = 0.3) +
		labs(
			title = title,
			x = paste0("PCoA1 (", axis1, "%)"),
			y = paste0("PCoA2 (", axis2, "%)")
		) +
		theme_minimal(base_size = 12) +
		coord_equal() +
		theme(legend.position = if (!is.na(group_var) && group_var %in% colnames(scores)) "top" else "none")

	if (!is.na(group_var) && group_var %in% colnames(scores)) {
		p <- p + geom_point(aes(color = .data[[group_var]]), size = 3, alpha = 0.85) + labs(color = group_var)
	} else {
		p <- p + geom_point(size = 3, alpha = 0.85)
	}

	ggsave(
		filename = file.path(out_fig_dir, file_name),
		plot = p,
		width = 7.5,
		height = 6.5,
		dpi = 300
	)
}

bray_dist <- phyloseq::distance(ps_rel, method = "bray")
make_pcoa_plot(
	dist_obj = bray_dist,
	ps_obj = ps_rel,
	title = "Bray-Curtis PCoA",
	file_name = "beta_pcoa_bray_curtis.png",
	group_var = group_var
)
cat("Saved Bray-Curtis PCoA to outputs/figures/beta_pcoa_bray_curtis.png\n")

ps_tree_candidate <- phy_tree(ps_rel, errorIfNULL = FALSE)
if (!is.null(phy_tree_obj) && !is.null(ps_tree_candidate) && length(intersect(ps_tree_candidate$tip.label, taxa_names(ps_rel))) > 0) {
	shared_tips <- intersect(ps_tree_candidate$tip.label, taxa_names(ps_rel))
	if (length(shared_tips) > 2) {
		ps_rel_tree <- prune_taxa(shared_tips, ps_rel)
		tree_tips <- phy_tree(ps_rel_tree, errorIfNULL = FALSE)$tip.label
		ps_rel_tree <- prune_taxa(intersect(taxa_names(ps_rel_tree), tree_tips), ps_rel_tree)
		if (ntaxa(ps_rel_tree) > 2) {
			wunifrac_dist <- phyloseq::distance(ps_rel_tree, method = "wunifrac")
			make_pcoa_plot(
				dist_obj = wunifrac_dist,
				ps_obj = ps_rel_tree,
				title = "Weighted UniFrac PCoA",
				file_name = "beta_pcoa_weighted_unifrac.png",
				group_var = group_var
			)
			cat("Saved weighted UniFrac PCoA to outputs/figures/beta_pcoa_weighted_unifrac.png\n")
		}
	}
}

nmds_res <- vegan::metaMDS(bray_dist, k = 2, trymax = 100, autotransform = FALSE)
nmds_scores <- as.data.frame(scores(nmds_res))
nmds_scores$Sample <- rownames(nmds_scores)
if (!is.null(sample_metadata)) {
	nmds_scores <- merge(nmds_scores, sample_metadata, by.x = "Sample", by.y = "row.names", all.x = TRUE)
}

nmds_plot <- ggplot(nmds_scores, aes(x = NMDS1, y = NMDS2)) +
	geom_hline(yintercept = 0, color = "grey85", linewidth = 0.3) +
	geom_vline(xintercept = 0, color = "grey85", linewidth = 0.3) +
	labs(
		title = "Bray-Curtis NMDS",
		subtitle = paste0("Stress = ", round(nmds_res$stress, 3)),
		x = "NMDS1",
		y = "NMDS2"
	) +
	theme_minimal(base_size = 12) +
	coord_equal() +
	theme(legend.position = if (!is.na(group_var) && group_var %in% colnames(nmds_scores)) "top" else "none")

if (!is.na(group_var) && group_var %in% colnames(nmds_scores)) {
	nmds_plot <- nmds_plot + geom_point(aes(color = .data[[group_var]]), size = 3, alpha = 0.85) + labs(color = group_var)
} else {
	nmds_plot <- nmds_plot + geom_point(size = 3, alpha = 0.85)
}

ggsave(
	filename = file.path(out_fig_dir, "beta_nmds_bray_curtis.png"),
	plot = nmds_plot,
	width = 7.5,
	height = 6.5,
	dpi = 300
)
cat("Saved Bray-Curtis NMDS to outputs/figures/beta_nmds_bray_curtis.png\n")

make_heatmap <- function(ps_obj, rank = "ASV", top_n = 30, file_name = "asv_heatmap_complexheatmap.png") {
	ps_top <- prune_taxa(names(sort(taxa_sums(ps_obj), decreasing = TRUE))[seq_len(min(top_n, ntaxa(ps_obj)))], ps_obj)
	ps_top <- transform_sample_counts(ps_top, function(x) {
		total <- sum(x)
		if (total == 0) {
			return(x)
		}
		x / total
	})

	mat <- as.matrix(otu_table(ps_top))
	if (!taxa_are_rows(ps_top)) {
		mat <- t(mat)
	}

	mat <- log10(mat + 1e-6)

	row_labels <- rownames(mat)
	if (!is.null(tax_table(ps_top, errorIfNULL = FALSE))) {
		tax_df <- as.data.frame(tax_table(ps_top), stringsAsFactors = FALSE)
		label_rank <- if (rank %in% colnames(tax_df)) rank else if ("Genus" %in% colnames(tax_df)) "Genus" else NULL
		if (!is.null(label_rank)) {
			labels <- tax_df[[label_rank]]
			labels[is.na(labels) | labels == ""] <- rownames(tax_df)[is.na(labels) | labels == ""]
			row_labels <- make.unique(as.character(labels))
			rownames(mat) <- row_labels
		}
	}

	ann_col <- NULL
	if (!is.null(sample_metadata)) {
		ann_df <- as.data.frame(sample_data(ps_top))
		ann_df <- ann_df[colnames(mat), , drop = FALSE]
		if (!is.na(group_var) && group_var %in% colnames(ann_df)) {
			ann_df[[group_var]] <- as.factor(ann_df[[group_var]])
			ann_col <- HeatmapAnnotation(df = ann_df[, group_var, drop = FALSE])
		}
	}

	ann_row <- NULL
	if (!is.null(tax_table(ps_top, errorIfNULL = FALSE))) {
		tax_df <- as.data.frame(tax_table(ps_top), stringsAsFactors = FALSE)
		if (all(c("Phylum", "Genus") %in% colnames(tax_df))) {
			ann_row <- rowAnnotation(
				Phylum = tax_df$Phylum,
				Genus = tax_df$Genus
			)
		}
	}

	ht <- Heatmap(
		mat,
		name = "log10(rel. ab.)",
		col = circlize::colorRamp2(
			c(min(mat, na.rm = TRUE), median(mat, na.rm = TRUE), max(mat, na.rm = TRUE)),
			c("#08306b", "#f7f7f7", "#67000d")
		),
		cluster_rows = TRUE,
		cluster_columns = TRUE,
		clustering_method_rows = "ward.D2",
		clustering_method_columns = "ward.D2",
		show_row_names = TRUE,
		show_column_names = TRUE,
		row_names_gp = grid::gpar(fontsize = 8),
		column_names_gp = grid::gpar(fontsize = 8),
		column_names_rot = 45,
		top_annotation = ann_col,
		left_annotation = ann_row,
		heatmap_legend_param = list(title = "log10\nrelative abundance")
	)

	png(file.path(out_fig_dir, file_name), width = 1800, height = 1400, res = 200)
	draw(ht, heatmap_legend_side = "right", annotation_legend_side = "right")
	dev.off()
	cat("Saved heatmap to outputs/figures/", file_name, " using ward.D2 clustering for rows and columns.\n", sep = "")
}

make_heatmap(
	ps_obj = ps_rel,
	rank = "Genus",
	top_n = 30,
